{
  "name": "hal-publication-integrator",
  "version": "4.1.0",
  "description": "JavaScript module to integrate a researcher's HAL publication list into a website.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tschmoderer/hal-bibliography-integrator.git"
  },
  "author": "Timothée Schmoderer",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/tschmoderer/hal-bibliography-integrator/issues"
  },
  "homepage": "https://github.com/tschmoderer/hal-bibliography-integrator#readme",
  "keywords": [
    "hal-api",
    "bibliography",
    "academic-website",
    "research-website"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/hal-bibliography-integrator.min.cjs",
  "module": "./dist/hal-bibliography-integrator.js",
  "exports": {
    ".": {
      "import": "./dist/hal-bibliography-integrator.js",
      "require": "./dist/hal-bibliography-integrator.min.cjs"
    },
    "./wordcloud": {
      "import": "./dist/hal-bibliography-integrator-wordcloud.js",
      "require": "./dist/hal-bibliography-integrator-wordcloud.min.cjs"
    },
    "./artscore": {
      "import": "./dist/hal-bibliography-integrator-artscore.js",
      "require": "./dist/hal-bibliography-integrator-artscore.min.cjs"
    },
    "./charts": {
      "import": "./dist/hal-bibliography-integrator-charts.js",
      "require": "./dist/hal-bibliography-integrator-charts.min.cjs"
    }
  },
  "scripts": {
    "dev": "vite --config config/vite.config.js",
    "build:lib": "vite build --mode production --config config/vite.config.js",
    "build:demo": "vite build --mode production --config config/vite.config.demo.js",
    "build": "npm run build:lib && npm run build:demo",
    "preview": "vite preview --config config/vite.config.js",
    "preview:demo": "vite preview --config config/vite.config.demo.js",
    "version:patch": "npm version patch && git push --follow-tags",
    "version:minor": "npm version minor && git push --follow-tags",
    "version:major": "npm version major && git push --follow-tags"
  },
  "devDependencies": {
    "sass-embedded": "^1.99.0",
    "vite": "^8.0.7"
  }
}
